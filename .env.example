# Alpaca paper trading credentials
ALPACA_API_KEY=replace_me
ALPACA_SECRET_KEY=replace_me
ALPACA_PAPER=true

# Strategy universe
SYMBOLS=AAPL,MSFT,NVDA,TSLA,AMZN

# Trading cadence and safeguards
LOOP_SECONDS=1800
MAX_POSITION_PCT=0.10
MAX_TOTAL_EXPOSURE_PCT=0.60
MAX_DAILY_LOSS_PCT=0.03
MAX_DRAWDOWN_PCT=0.08
STOP_LOSS_PCT=0.04
TAKE_PROFIT_PCT=0.10
MIN_SIGNAL_SCORE=0.35
MAX_TRADES_PER_DAY=8
COOLDOWN_MINUTES=60

# Backtest assumptions
INITIAL_CASH=100000
SLIPPAGE_BPS=10
FEE_PER_TRADE=0

# Optional data sources
# Comma-separated RSS feeds. Examples: company IR feeds, SEC feeds, trusted financial/news feeds.
RSS_FEEDS=

# Optional X/Twitter recent search. Requires API access and may be rate-limited/paid.
X_BEARER_TOKEN=
X_QUERY_TEMPLATE="{symbol} stock OR ${symbol} -is:retweet lang:en"
